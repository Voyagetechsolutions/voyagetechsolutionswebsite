---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import PageHeader from "../components/PageHeader.astro";
import CtaBand from "../components/CtaBand.astro";
import { SITE } from "../config/site.ts";

const points = [
  {
    title: "Browser-native, on-device",
    body: "Redaction happens in the browser, on the user's machine. Sensitive data is caught before it ever leaves to an external AI tool.",
  },
  {
    title: "Built for regulated teams",
    body: "For ops, support and finance staff who want to use AI tools without sending customer PII to a third party.",
  },
  {
    title: "Proof we understand compliance",
    body: "Endon AI exists because we take data-protection seriously. It's the same rigour we bring to client work.",
  },
];
---

<Base
  title="Endon AI"
  description="Endon AI — browser-native, on-device PII redaction before your data reaches external AI tools."
>
  <PageHeader eyebrow="Our product" title="Endon AI">
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-[var(--color-muted)]">
      On-device PII redaction that strips sensitive data <em>before</em> it
      reaches external AI tools — so regulated teams can use AI without leaking
      customer data.
    </p>
    <div class="mt-8">
      <Button href={SITE.links.endonAi} external>Visit endonai.com</Button>
    </div>
  </PageHeader>

  <section class="mx-auto max-w-6xl px-5 pb-16 sm:px-6">
    <div class="grid gap-5 md:grid-cols-3">
      {
        points.map((p) => (
          <div class="card p-6">
            <h2 class="text-lg font-semibold text-[var(--color-ink)]">
              {p.title}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
              {p.body}
            </p>
          </div>
        ))
      }
    </div>

    <p class="mt-10 max-w-2xl text-sm text-[var(--color-muted)]">
      This page is here to show the depth behind our client work — not to sell
      Endon AI. If you want the full product, head to
      <a
        href={SITE.links.endonAi}
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium text-[var(--color-brand)] hover:underline"
        >endonai.com</a
      >.
    </p>
  </section>

  <CtaBand
    heading="Need software built for a regulated environment?"
    sub="If data sensitivity is part of your problem, it's part of ours too. Let's talk through what you're handling."
  />
</Base>
