---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import CtaBand from "../components/CtaBand.astro";
import { SITE } from "../config/site.ts";

const services = [
  {
    title: "Document automation",
    body: "Turn manual, error-prone paperwork — invoices, delivery notes, customs docs — into rule-driven pipelines that produce clean, consistent output every time.",
  },
  {
    title: "Compliance tooling",
    body: "Software built for regulated environments (POPIA, data-protection) where getting the handling of sensitive data wrong is not an option.",
  },
  {
    title: "Full-stack product builds",
    body: "End-to-end web apps and internal tools, shipped to production — not prototypes that stall before they reach your team.",
  },
];

const proof = [
  {
    name: "Zimbabwe Shipping",
    line: "Document & freight-ops pipeline for a cross-border logistics operation.",
  },
  {
    name: "Endon AI",
    line: "Browser-native, on-device PII redaction for regulated teams.",
  },
];
---

<Base>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(60%_60%_at_50%_0%,var(--color-brand-soft),transparent_70%)]"
    >
    </div>
    <div class="mx-auto max-w-6xl px-5 pt-20 pb-16 sm:px-6 sm:pt-28 sm:pb-20">
      <p
        class="inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] bg-white px-3 py-1 text-xs font-medium text-[var(--color-muted)]"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-brand)]"></span>
        Logistics &amp; fintech software
      </p>
      <h1
        class="mt-6 max-w-3xl text-4xl font-semibold tracking-tight text-[var(--color-ink)] sm:text-5xl sm:leading-[1.07]"
      >
        We build document and compliance automation for logistics and fintech
        teams.
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-[var(--color-muted)]">
        Shipping production software, not slide decks. We take the paperwork and
        regulated workflows that slow your team down and turn them into reliable,
        automated systems.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href={SITE.calendarUrl} external>Book a 20-min call</Button>
        <Button href="/work" variant="ghost">See the work</Button>
      </div>
    </div>
  </section>

  <!-- Proof strip -->
  <section class="border-y border-[var(--color-line)] bg-[var(--color-mist)]">
    <div class="mx-auto max-w-6xl px-5 py-10 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
        Proof of work
      </p>
      <div class="mt-5 grid gap-6 sm:grid-cols-2">
        {
          proof.map((p) => (
            <div class="flex items-start gap-3">
              <span class="mt-1 grid h-8 w-8 shrink-0 place-items-center rounded-lg border border-[var(--color-line)] bg-white text-sm font-bold text-[var(--color-ink)]">
                {p.name.charAt(0)}
              </span>
              <div>
                <p class="font-semibold text-[var(--color-ink)]">{p.name}</p>
                <p class="text-sm text-[var(--color-muted)]">{p.line}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- What we do -->
  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-6">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight">What we do</h2>
      <p class="mt-3 text-[var(--color-muted)]">
        Three things we do well, framed by the outcome you get — not the tech we
        use to get there.
      </p>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {
        services.map((s) => (
          <div class="rounded-[var(--radius-card)] border border-[var(--color-line)] bg-white p-6 transition-shadow hover:shadow-sm">
            <h3 class="text-lg font-semibold text-[var(--color-ink)]">
              {s.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
              {s.body}
            </p>
          </div>
        ))
      }
    </div>
    <div class="mt-8">
      <a
        href="/what-we-do"
        class="text-sm font-medium text-[var(--color-brand)] hover:underline"
        >How we work with you →</a
      >
    </div>
  </section>

  <!-- Case study teaser -->
  <section class="border-t border-[var(--color-line)] bg-[var(--color-mist)]">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-6">
      <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand)]">
            Case study
          </p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">
            56 invoices, one repeatable PDF pipeline
          </h2>
          <p class="mt-4 leading-relaxed text-[var(--color-muted)]">
            A logistics team was hand-formatting invoices one by one. We built a
            formatting-rule-driven pipeline that converts their raw invoice data
            into clean, consistent PDFs — so the work that used to take hours runs
            in minutes, the same way every time.
          </p>
          <div class="mt-6">
            <Button href="/work" variant="ghost">Read the full story</Button>
          </div>
        </div>
        <div class="rounded-[var(--radius-card)] border border-[var(--color-line)] bg-white p-7">
          <dl class="grid grid-cols-2 gap-6">
            <div>
              <dt class="text-sm text-[var(--color-muted)]">Documents automated</dt>
              <dd class="mt-1 text-3xl font-semibold text-[var(--color-ink)]">56</dd>
            </div>
            <div>
              <dt class="text-sm text-[var(--color-muted)]">Manual formatting</dt>
              <dd class="mt-1 text-3xl font-semibold text-[var(--color-ink)]">0</dd>
            </div>
            <div>
              <dt class="text-sm text-[var(--color-muted)]">Output</dt>
              <dd class="mt-1 text-lg font-semibold text-[var(--color-ink)]">
                Rule-driven PDF
              </dd>
            </div>
            <div>
              <dt class="text-sm text-[var(--color-muted)]">Consistency</dt>
              <dd class="mt-1 text-lg font-semibold text-[var(--color-ink)]">
                Every run
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
