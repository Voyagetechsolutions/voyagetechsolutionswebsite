---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import CtaBand from "../components/CtaBand.astro";
import { SITE } from "../config/site.ts";

// Three broad, outcome-first capabilities. `icon` is an SVG path drawn at
// 24x24 with currentColor stroke.
const services = [
  {
    title: "Web & mobile apps",
    body: "Full-stack web and mobile applications — designed, built and shipped to production, not left at the prototype stage.",
    icon: "M4 4h16v12H4z M2 20h20 M9 8h6 M9 12h4",
    img: "/images/service-web.webp",
  },
  {
    title: "Custom software & systems",
    body: "Internal tools, dashboards and line-of-business systems that put your operation on rails and scale past spreadsheets.",
    icon: "M9 8l-4 4 4 4 M15 8l4 4-4 4",
    img: "/images/service-systems.webp",
  },
  {
    title: "Automation & integrations",
    body: "We connect your tools and automate the manual work — from document pipelines and reporting to data flowing between systems.",
    icon: "M13 2L4 14h7l-1 8 9-12h-7z",
    img: "/images/service-automation.webp",
  },
];

// Capability marquee — signals the full range at a glance.
const capabilities = [
  "Web apps",
  "Mobile apps",
  "Custom software",
  "Dashboards",
  "APIs & integrations",
  "Automation",
  "AI features",
  "Document automation",
  "Compliance tooling",
  "Cloud & DevOps",
];

const proof = [
  {
    name: "Zimbabwe Shipping",
    line: "Document & freight-ops pipeline for a cross-border logistics operation.",
  },
  {
    name: "Endon AI",
    line: "Browser-native, on-device PII redaction for regulated teams.",
  },
];

// FAQ — answers real buyer questions (conversion) and earns FAQ rich results.
const faqs = [
  {
    q: "What kind of software does Voyage build?",
    a: "We're a full-stack software studio. We build web applications, mobile apps, custom internal systems and dashboards, plus automation and integrations between your existing tools. If it runs on software, there's a good chance we build it.",
  },
  {
    q: "Do you work with clients outside South Africa?",
    a: "Yes. We're based in South Africa and work with clients locally and worldwide, remotely. Most projects are run over calls, shared docs and regular demos, so location isn't a barrier.",
  },
  {
    q: "How much does a software project cost?",
    a: "It depends entirely on scope. We scope the work with you first and give a clear estimate before anything is committed — no open-ended billing. The fastest way to a number is a short call.",
  },
  {
    q: "How long does a build take?",
    a: "Small tools can ship in a couple of weeks; larger products run longer. We ship in phases to production rather than disappearing for months, so you see working software early and often.",
  },
  {
    q: "Can you take over an existing or stalled project?",
    a: "Yes. We regularly pick up half-finished builds, fix what's broken, and get them shipped. We'll review the current state honestly and tell you the most sensible path forward.",
  },
  {
    q: "Do you build software for regulated, data-sensitive teams?",
    a: "Yes — we build POPIA / data-protection-aware software with the right guardrails. Our own product, Endon AI, does on-device PII redaction, so handling sensitive data carefully is core to how we work.",
  },
];

const faqSchema = [
  {
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<Base schema={faqSchema}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="glow pointer-events-none absolute inset-0 -z-10"></div>
    <div class="grid-texture pointer-events-none absolute inset-0 -z-10"></div>
    <div
      class="mx-auto grid max-w-6xl items-center gap-12 px-5 pt-16 pb-16 sm:px-6 sm:pt-24 sm:pb-20 lg:grid-cols-[1.1fr_0.9fr]"
    >
      <div>
        <p
          class="inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] bg-[var(--color-surface)] px-3 py-1 text-xs font-medium text-[var(--color-ink-soft)]"
        >
          <span
            class="pulse-dot h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"
          ></span>
          Full-stack software studio
        </p>
        <h1
          class="mt-6 max-w-2xl text-4xl font-semibold tracking-tight text-[var(--color-ink)] sm:text-[3.4rem] sm:leading-[1.04]"
        >
          We build <span class="text-gradient">software</span> for
          <span class="accent-underline">everything</span> your business runs on.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-[var(--color-muted)]">
          Web and mobile apps, custom systems, automation, integrations and AI —
          designed, built and shipped to production. Whatever your business needs
          built, we build it. No slide decks, no stalled prototypes.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={SITE.calendarUrl} external class="cta-shimmer"
            >Book a 20-min call</Button
          >
          <Button href="/work" variant="ghost">See the work</Button>
        </div>
        <ul
          class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[var(--color-muted)]"
        >
          <li class="flex items-center gap-2">
            <span class="text-[var(--color-accent)]">✓</span> POPIA / data-protection aware
          </li>
          <li class="flex items-center gap-2">
            <span class="text-[var(--color-accent)]">✓</span> Shipped to production
          </li>
          <li class="flex items-center gap-2">
            <span class="text-[var(--color-accent)]">✓</span> Direct with the builder
          </li>
        </ul>
      </div>

      <div class="relative hidden lg:block">
        <div class="glow pointer-events-none absolute -inset-6 -z-10 opacity-80"></div>
        <div
          class="overflow-hidden rounded-3xl border border-[var(--color-line)] shadow-2xl shadow-[var(--color-brand)]/20"
        >
          <img
            src="/images/hero.webp"
            width="1264"
            height="848"
            alt="Freight and shipping documents flowing into an automated, structured data pipeline"
            class="h-auto w-full"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        <!-- floating proof badge for life + conversion -->
        <div
          class="absolute -bottom-5 -left-5 flex items-center gap-3 rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)]/90 px-4 py-3 shadow-xl backdrop-blur-md"
        >
          <span
            class="grid h-9 w-9 place-items-center rounded-xl bg-[var(--color-brand-soft)] text-[var(--color-accent)]"
            aria-hidden="true">✓</span
          >
          <div class="leading-tight">
            <p class="text-sm font-semibold text-[var(--color-ink)]">
              Production software
            </p>
            <p class="text-xs text-[var(--color-muted)]">shipped, not slide decks</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Capability marquee -->
  <section class="border-y border-[var(--color-line)] bg-[var(--color-surface)]/40 py-5">
    <div class="marquee">
      <div class="marquee-track">
        {
          [...capabilities, ...capabilities].map((c) => (
            <span class="mx-5 inline-flex items-center gap-3 text-sm font-medium text-[var(--color-ink-soft)]">
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-brand)]" />
              {c}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Proof strip -->
  <section class="border-b border-[var(--color-line)] bg-[var(--color-mist)]">
    <div class="mx-auto max-w-6xl px-5 py-10 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
        Proof of work
      </p>
      <div class="mt-5 grid gap-6 sm:grid-cols-2">
        {
          proof.map((p) => (
            <div class="flex items-start gap-3">
              <span class="mt-1 grid h-8 w-8 shrink-0 place-items-center rounded-lg border border-[var(--color-line)] bg-[var(--color-surface-2)] text-sm font-bold text-[var(--color-brand)]">
                {p.name.charAt(0)}
              </span>
              <div>
                <p class="font-semibold text-[var(--color-ink)]">{p.name}</p>
                <p class="text-sm text-[var(--color-muted)]">{p.line}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Studio intro (geo + entity keywords for SEO) -->
  <section class="mx-auto max-w-6xl px-5 pt-20 sm:px-6">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
        A South&nbsp;Africa–based software studio, building for clients
        worldwide.
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-[var(--color-muted)]">
        Voyage Technology Solutions is a full-stack software development
        company. We design and build web applications, mobile apps, custom
        internal systems, automation and integrations — for startups and
        established teams in South Africa and across the globe. Whatever you
        need built in software, we ship it to production.
      </p>
    </div>
  </section>

  <!-- What we do -->
  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-6">
    <div class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand)]">
        What we do
      </p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
        If it runs on software, we build it.
      </h2>
      <p class="mt-4 text-[var(--color-muted)]">
        From a single app to the systems your whole operation depends on —
        framed by the outcome you get, not the tech behind it.
      </p>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {
        services.map((s) => (
          <div class="card group overflow-hidden">
            <div class="relative h-44 overflow-hidden bg-[var(--color-bg)]">
              <img
                src={s.img}
                width="1024"
                height="1024"
                alt={`${s.title} — software development by ${SITE.name}`}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.06]"
              />
              <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-[var(--color-surface)] to-transparent" />
            </div>
            <div class="p-6 pt-0">
              <span class="relative -mt-7 mb-4 inline-grid h-12 w-12 place-items-center rounded-xl border border-[var(--color-line)] bg-[var(--color-surface-2)] text-[var(--color-accent)] shadow-lg transition-colors group-hover:border-[var(--color-brand)]">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={s.icon} />
                </svg>
              </span>
              <h3 class="text-lg font-semibold text-[var(--color-ink)]">
                {s.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
                {s.body}
              </p>
            </div>
          </div>
        ))
      }
    </div>
    <div class="mt-8">
      <a
        href="/what-we-do"
        class="text-sm font-medium text-[var(--color-brand)] hover:underline"
        >See the full range →</a
      >
    </div>
  </section>

  <!-- Case study teaser -->
  <section class="border-t border-[var(--color-line)] bg-[var(--color-mist)]">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-6">
      <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand)]">
            Case study
          </p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">
            56 invoices, one repeatable PDF pipeline
          </h2>
          <p class="mt-4 leading-relaxed text-[var(--color-muted)]">
            A logistics team was hand-formatting invoices one by one. We built a
            formatting-rule-driven pipeline that converts their raw invoice data
            into clean, consistent PDFs — so the work that used to take hours runs
            in minutes, the same way every time.
          </p>
          <div class="mt-6">
            <Button href="/work" variant="ghost">Read the full story</Button>
          </div>
        </div>
        <div class="rounded-[var(--radius-card)] border border-[var(--color-line)] bg-[var(--color-surface)] p-7">
          <dl class="grid grid-cols-2 gap-6">
            <div>
              <dt class="text-sm text-[var(--color-muted)]">Documents automated</dt>
              <dd class="mt-1 text-3xl font-semibold text-[var(--color-ink)]">56</dd>
            </div>
            <div>
              <dt class="text-sm text-[var(--color-muted)]">Manual formatting</dt>
              <dd class="mt-1 text-3xl font-semibold text-[var(--color-ink)]">0</dd>
            </div>
            <div>
              <dt class="text-sm text-[var(--color-muted)]">Output</dt>
              <dd class="mt-1 text-lg font-semibold text-[var(--color-ink)]">
                Rule-driven PDF
              </dd>
            </div>
            <div>
              <dt class="text-sm text-[var(--color-muted)]">Consistency</dt>
              <dd class="mt-1 text-lg font-semibold text-[var(--color-ink)]">
                Every run
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ (also emitted as FAQPage structured data) -->
  <section class="mx-auto max-w-3xl px-5 py-20 sm:px-6">
    <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand)]">
      Questions, answered
    </p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
      Frequently asked
    </h2>
    <div class="mt-8 divide-y divide-[var(--color-line)] border-y border-[var(--color-line)]">
      {
        faqs.map((f) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left font-medium text-[var(--color-ink)]">
              {f.q}
              <span class="shrink-0 text-[var(--color-brand)] transition-transform duration-200 group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
              {f.a}
            </p>
          </details>
        ))
      }
    </div>
  </section>

  <CtaBand />
</Base>
