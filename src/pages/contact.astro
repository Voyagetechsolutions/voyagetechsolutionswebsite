---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import { SITE } from "../config/site.ts";
---

<Base
  title="Contact"
  description="Book a 20-minute call or send us a note. We reply to everything."
>
  <section class="mx-auto max-w-6xl px-5 pt-20 pb-20 sm:px-6">
    <h1 class="max-w-3xl text-4xl font-semibold tracking-tight sm:text-5xl">
      Let's talk
    </h1>
    <p class="mt-5 max-w-xl text-lg leading-relaxed text-[var(--color-muted)]">
      The fastest path is a 20-minute call. Prefer to write first? Send a note —
      we reply to everything.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      <!-- Direct options -->
      <div class="rounded-[var(--radius-card)] border border-[var(--color-line)] bg-white p-7">
        <h2 class="text-lg font-semibold text-[var(--color-ink)]">
          Book a call
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
          Pick a time that works for you. No prep needed — just bring the
          workflow that's slowing your team down.
        </p>
        <div class="mt-5">
          <Button href={SITE.calendarUrl} external>Open the calendar</Button>
        </div>

        <hr class="my-7 border-[var(--color-line)]" />

        <h2 class="text-lg font-semibold text-[var(--color-ink)]">Email us</h2>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
          Prefer email? Reach us directly at
          <a
            href={`mailto:${SITE.email}`}
            class="font-medium text-[var(--color-brand)] hover:underline"
            >{SITE.email}</a
          >.
        </p>
      </div>

      <!-- Short form: composes a mailto, no backend required -->
      <div class="rounded-[var(--radius-card)] border border-[var(--color-line)] bg-white p-7">
        <h2 class="text-lg font-semibold text-[var(--color-ink)]">
          Send a note
        </h2>
        <form id="contact-form" class="mt-5 space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-[var(--color-ink-soft)]"
              >Name</label
            >
            <input
              id="name"
              name="name"
              type="text"
              required
              class="mt-1 w-full rounded-lg border border-[var(--color-line)] bg-white px-3 py-2 text-sm focus:border-[var(--color-brand)] focus:outline-none"
            />
          </div>
          <div>
            <label for="company" class="block text-sm font-medium text-[var(--color-ink-soft)]"
              >Company</label
            >
            <input
              id="company"
              name="company"
              type="text"
              class="mt-1 w-full rounded-lg border border-[var(--color-line)] bg-white px-3 py-2 text-sm focus:border-[var(--color-brand)] focus:outline-none"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-[var(--color-ink-soft)]"
              >What can we help with?</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="mt-1 w-full rounded-lg border border-[var(--color-line)] bg-white px-3 py-2 text-sm focus:border-[var(--color-brand)] focus:outline-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-full bg-[var(--color-brand)] px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-brand-dark)]"
          >
            Send via email
          </button>
          <p class="text-xs text-[var(--color-muted)]">
            This opens your email app with the message ready to send — no data is
            stored here.
          </p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ email: SITE.email }}>
    const form = document.getElementById("contact-form");
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = (data.get("name") || "").toString().trim();
      const company = (data.get("company") || "").toString().trim();
      const message = (data.get("message") || "").toString().trim();
      const subject = `Enquiry from ${name}${company ? ` (${company})` : ""}`;
      const body = `${message}\n\n— ${name}${company ? `, ${company}` : ""}`;
      window.location.href = `mailto:${email}?subject=${encodeURIComponent(
        subject
      )}&body=${encodeURIComponent(body)}`;
    });
  </script>
</Base>
