---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import CtaBand from "../components/CtaBand.astro";

// Lead with the strongest, most concrete story. Add more only when each
// new one is as solid as this — three thin stories are weaker than one good one.
const caseStudies = [
  {
    tag: "Logistics · Document automation",
    title: "A repeatable PDF pipeline for invoice formatting",
    problem:
      "A logistics team was formatting invoices by hand — opening each one, applying the same layout rules from memory, exporting, repeating. It was slow, and consistency depended on whoever happened to be doing it that day.",
    built:
      "We built a formatting-rule-driven pipeline that takes the raw invoice data and applies a single, codified set of layout rules to produce a clean PDF. The rules live in one place, so a change applies everywhere and the output never drifts.",
    results: [
      { value: "56", label: "invoices converted into the pipeline" },
      { value: "1", label: "source of formatting rules, applied every run" },
      { value: "0", label: "manual re-formatting per document" },
    ],
    // TODO: drop in the real timeframe (e.g. "built in 3 days") once confirmed.
    note: "Output is identical and correct on every run — the same input always produces the same document.",
  },
  {
    tag: "Logistics · Freight ops",
    title: "Zimbabwe Shipping — document & freight-ops pipeline",
    problem:
      "A cross-border shipping operation needed its document and operational workflow captured in software instead of living across spreadsheets and email.",
    built:
      "We're building the document-generation and operations tooling that turns that manual process into a system the team can rely on day to day.",
    results: [
      { value: "Live", label: "engagement, in active development" },
      { value: "Cross-border", label: "logistics workflow" },
    ],
    note: "Ask us for a walkthrough of where this stands today.",
  },
];
---

<Base
  title="Work"
  description="Real projects with real results — document automation and logistics tooling shipped to production."
>
  <PageHeader
    eyebrow="Proof of work"
    title="The work"
    lead="Proof beats adjectives. Here's what we built, the problem it solved, and what changed as a result."
  />

  <section class="mx-auto max-w-6xl space-y-6 px-5 pb-16 sm:px-6">
    {
      caseStudies.map((c) => (
        <article class="rounded-[var(--radius-card)] border border-[var(--color-line)] bg-[var(--color-surface)] p-7 sm:p-9">
          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand)]">
            {c.tag}
          </p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-[var(--color-ink)]">
            {c.title}
          </h2>

          <div class="mt-6 grid gap-8 md:grid-cols-2">
            <div>
              <p class="text-sm font-medium text-[var(--color-ink-soft)]">
                The problem
              </p>
              <p class="mt-1 text-sm leading-relaxed text-[var(--color-muted)]">
                {c.problem}
              </p>
            </div>
            <div>
              <p class="text-sm font-medium text-[var(--color-ink-soft)]">
                What we built
              </p>
              <p class="mt-1 text-sm leading-relaxed text-[var(--color-muted)]">
                {c.built}
              </p>
            </div>
          </div>

          <div class="mt-7 flex flex-wrap gap-3 border-t border-[var(--color-line)] pt-6">
            {c.results.map((r) => (
              <div class="rounded-xl border border-[var(--color-line)] bg-[var(--color-surface-2)] px-4 py-3">
                <p class="text-xl font-semibold text-[var(--color-ink)]">
                  {r.value}
                </p>
                <p class="text-xs text-[var(--color-muted)]">{r.label}</p>
              </div>
            ))}
          </div>

          <p class="mt-5 text-sm italic text-[var(--color-muted)]">{c.note}</p>
        </article>
      ))
    }
  </section>

  <CtaBand
    heading="Want results like these for your team?"
    sub="The fastest way to find out if we can help is a short call. Bring the workflow that's slowing you down."
  />
</Base>
