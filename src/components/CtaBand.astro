---
import { SITE, BOOKING_HREF, HAS_CALENDAR } from "../config/site.ts";
import Button from "./Button.astro";

interface Props {
  heading?: string;
  sub?: string;
}

const {
  heading = "Have something that needs building?",
  sub = "App, internal tool, automation, integration — whatever it is, tell us on a 20-minute call and we'll tell you straight how we'd build it. No pitch.",
} = Astro.props;
---

<section class="px-5 py-16 sm:px-6">
  <div
    class="relative mx-auto max-w-5xl overflow-hidden rounded-3xl border border-[var(--color-line)] bg-gradient-to-br from-[var(--color-surface-2)] via-[var(--color-surface)] to-[var(--color-bg)] px-7 py-12 text-white sm:px-12 sm:py-14"
  >
    <div
      class="pointer-events-none absolute -right-16 -top-24 h-64 w-64 rounded-full bg-[var(--color-brand)] opacity-30 blur-3xl"
    >
    </div>
    <div class="relative max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        {heading}
      </h2>
      <p class="mt-3 text-[15px] leading-relaxed text-white/70">{sub}</p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <Button href={BOOKING_HREF} external>{HAS_CALENDAR ? "Book a call" : "Email us to book"}</Button>
        <Button href={`mailto:${SITE.email}`} variant="ghost" class="!bg-transparent !text-white !border-white/25 hover:!border-white hover:!text-white">
          Email us
        </Button>
      </div>
    </div>
  </div>
</section>
