---
import { SITE } from "../config/site.ts";
import Button from "./Button.astro";

interface Props {
  heading?: string;
  sub?: string;
}

const {
  heading = "Have a document or compliance bottleneck?",
  sub = "Tell us the workflow that's eating your team's time. We'll tell you, on a 20-minute call, whether it's worth automating — no pitch.",
} = Astro.props;
---

<section class="px-5 py-16 sm:px-6">
  <div
    class="mx-auto max-w-5xl overflow-hidden rounded-3xl bg-[var(--color-ink)] px-7 py-12 text-white sm:px-12 sm:py-14"
  >
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        {heading}
      </h2>
      <p class="mt-3 text-[15px] leading-relaxed text-white/70">{sub}</p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <Button href={SITE.calendarUrl} external>Book a call</Button>
        <Button href={`mailto:${SITE.email}`} variant="ghost" class="!bg-transparent !text-white !border-white/25 hover:!border-white hover:!text-white">
          Email us
        </Button>
      </div>
    </div>
  </div>
</section>
