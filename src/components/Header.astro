---
import { SITE } from "../config/site.ts";
import Button from "./Button.astro";

const nav = [
  { href: "/what-we-do", label: "What we do" },
  { href: "/work", label: "Work" },
  { href: "/endon-ai", label: "Endon AI" },
  { href: "/contact", label: "Contact" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="sticky top-0 z-40 border-b border-[var(--color-line)] bg-[var(--color-bg)]/80 backdrop-blur-md"
>
  <div
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-6"
  >
    <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight">
      <span
        class="grid h-8 w-8 place-items-center rounded-lg bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-accent)] text-sm font-bold text-white shadow-md shadow-[var(--color-brand)]/30"
        aria-hidden="true">V</span
      >
      <span class="text-[15px]">{SITE.name}</span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-sm transition-colors hover:text-[var(--color-brand)]",
              path === item.href
                ? "text-[var(--color-brand)] font-medium"
                : "text-[var(--color-muted)]",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <Button href={SITE.calendarUrl} external class="hidden sm:inline-flex">
        Book a call
      </Button>
      <a
        href="/contact"
        class="text-sm font-medium text-[var(--color-ink)] md:hidden"
        >Contact</a
      >
    </div>
  </div>
</header>
