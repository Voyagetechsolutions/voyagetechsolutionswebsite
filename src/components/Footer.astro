---
import { SITE } from "../config/site.ts";
import Logo from "./Logo.astro";

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)] bg-[var(--color-mist)]">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-8 px-5 py-12 sm:px-6 md:flex-row md:items-start md:justify-between"
  >
    <div class="max-w-sm">
      <Logo />
      <p class="mt-4 text-sm text-[var(--color-muted)]">{SITE.tagline}</p>
    </div>

    <div class="grid grid-cols-2 gap-8 text-sm">
      <div>
        <p class="font-semibold text-[var(--color-ink)]">Site</p>
        <ul class="mt-3 space-y-2 text-[var(--color-muted)]">
          <li><a class="hover:text-[var(--color-brand)]" href="/what-we-do">What we do</a></li>
          <li><a class="hover:text-[var(--color-brand)]" href="/work">Work</a></li>
          <li><a class="hover:text-[var(--color-brand)]" href="/endon-ai">Endon AI</a></li>
          <li><a class="hover:text-[var(--color-brand)]" href="/contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <p class="font-semibold text-[var(--color-ink)]">Get in touch</p>
        <ul class="mt-3 space-y-2 text-[var(--color-muted)]">
          <li>
            <a class="hover:text-[var(--color-brand)]" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </li>
          {
            SITE.phone && (
              <li>
                <a
                  class="hover:text-[var(--color-brand)]"
                  href={`tel:${SITE.phone.replace(/\s/g, "")}`}
                >
                  {SITE.phone}
                </a>
              </li>
            )
          }
          <li>
            <a
              class="hover:text-[var(--color-brand)]"
              href={SITE.calendarUrl}
              target="_blank"
              rel="noopener noreferrer">Book a call</a
            >
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-[var(--color-line)]">
    <div
      class="mx-auto max-w-6xl px-5 py-5 text-xs text-[var(--color-muted)] sm:px-6"
    >
      © {year} {SITE.name}. Shipping production software, not slide decks.
    </div>
  </div>
</footer>
