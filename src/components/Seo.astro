---
import { SITE, SAME_AS } from "../config/site.ts";

interface Crumb {
  name: string;
  path: string;
}

interface Props {
  title?: string;
  description?: string;
  /** Extra keyword string for this page. */
  keywords?: string[];
  /** og:type — "website" (default) or "article". */
  type?: "website" | "article";
  /** Override the share image (absolute path). */
  image?: string;
  /** Breadcrumb trail (excluding Home, which is prepended). */
  breadcrumbs?: Crumb[];
  /** Extra JSON-LD nodes for this page (Service, FAQPage, etc.). */
  schema?: Record<string, unknown>[];
  /** Set true on pages that should not be indexed. */
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  keywords = SITE.keywords,
  type = "website",
  image = SITE.ogImage,
  breadcrumbs = [],
  schema = [],
  noindex = false,
} = Astro.props;

const origin = Astro.site ?? new URL(`https://${SITE.domain}`);
const canonical = new URL(Astro.url.pathname, origin);
const pageTitle = title
  ? `${title} — ${SITE.name}`
  : `${SITE.name} — Software Development Company in South Africa`;
const ogImageUrl = new URL(image, origin).href;
const logoUrl = new URL("/favicon.svg", origin).href;

// ---- JSON-LD @graph ----
const orgId = `${origin.origin}/#organization`;
const siteId = `${origin.origin}/#website`;

const organization: Record<string, unknown> = {
  "@type": "Organization",
  "@id": orgId,
  name: SITE.name,
  legalName: SITE.legalName,
  url: origin.origin,
  email: SITE.email,
  logo: logoUrl,
  image: ogImageUrl,
  description: SITE.description,
  ...(SAME_AS.length ? { sameAs: SAME_AS } : {}),
  ...(SITE.phone
    ? {
        contactPoint: {
          "@type": "ContactPoint",
          telephone: SITE.phone,
          email: SITE.email,
          contactType: "sales",
          areaServed: SITE.areaServed,
          availableLanguage: ["en"],
        },
      }
    : {}),
};

const website: Record<string, unknown> = {
  "@type": "WebSite",
  "@id": siteId,
  url: origin.origin,
  name: SITE.name,
  description: SITE.description,
  publisher: { "@id": orgId },
  inLanguage: "en",
};

// ProfessionalService = LocalBusiness subtype, ideal for an agency.
const localBusiness: Record<string, unknown> = {
  "@type": "ProfessionalService",
  "@id": `${origin.origin}/#localbusiness`,
  name: SITE.name,
  url: origin.origin,
  image: ogImageUrl,
  email: SITE.email,
  priceRange: SITE.priceRange,
  parentOrganization: { "@id": orgId },
  areaServed: SITE.areaServed,
  knowsAbout: SITE.keywords,
  ...(SITE.phone ? { telephone: SITE.phone } : {}),
  address: {
    "@type": "PostalAddress",
    ...(SITE.location.city ? { addressLocality: SITE.location.city } : {}),
    ...(SITE.location.region ? { addressRegion: SITE.location.region } : {}),
    addressCountry: SITE.location.countryCode,
  },
  ...(SITE.geo.lat && SITE.geo.lng
    ? {
        geo: {
          "@type": "GeoCoordinates",
          latitude: SITE.geo.lat,
          longitude: SITE.geo.lng,
        },
      }
    : {}),
};

const crumbList =
  breadcrumbs.length > 0
    ? [
        {
          "@type": "BreadcrumbList",
          itemListElement: [{ name: "Home", path: "/" }, ...breadcrumbs].map(
            (c, i) => ({
              "@type": "ListItem",
              position: i + 1,
              name: c.name,
              item: new URL(c.path, origin).href,
            })
          ),
        },
      ]
    : [];

const graph = {
  "@context": "https://schema.org",
  "@graph": [organization, website, localBusiness, ...crumbList, ...schema],
};
---

<!-- Primary meta -->
<title>{pageTitle}</title>
<meta name="description" content={description} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
<link rel="canonical" href={canonical.href} />
<meta
  name="robots"
  content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"}
/>
<meta name="author" content={SITE.name} />
<meta name="theme-color" content="#060a16" />
<meta name="generator" content={Astro.generator} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical.href} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content="en_ZA" />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${SITE.name} — software development studio`} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Icons + manifest -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Structured data -->
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(graph)}
/>
